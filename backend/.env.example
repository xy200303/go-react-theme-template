SERVER_PORT=8080
SERVER_MODE=debug
FRONTEND_DIST_DIR=web
SMS_VERIFY_ENABLED=true

POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/enterprise_web?sslmode=disable&TimeZone=Asia/Shanghai

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAY=7

TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

UPLOAD_DRIVER=auto
UPLOAD_LOCAL_PATH=uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_SUFFIX=jpg,jpeg,png,gif,webp

TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET_URL=
TENCENT_COS_BASE_URL=

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PHONE=13800000000
INIT_ADMIN_PASSWORD=admin1234
